#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
#  ez — Satellite Change Detection Service Tool
#
#  Auto-generated by CMake from ez.in.
#  Do NOT edit this file directly.
#  Edit ez.in, then re-run: cmake -S . -B build
# ──────────────────────────────────────────────────────────────

set -euo pipefail

# ── Embedded config (stamped by CMake) ────────────────────────
ROOT_DIR="@EZ_ROOT_DIR@"

SERVICES=(
@SERVICES_BASH@)

# ── Colours ───────────────────────────────────────────────────
BOLD=$(tput bold   2>/dev/null || printf '')
RESET=$(tput sgr0  2>/dev/null || printf '')
CYAN=$(tput setaf 6 2>/dev/null || printf '')
GREEN=$(tput setaf 2 2>/dev/null || printf '')
RED=$(tput setaf 1 2>/dev/null || printf '')
YELLOW=$(tput setaf 3 2>/dev/null || printf '')
DIM=$(tput dim     2>/dev/null || printf '')

# ── Usage ─────────────────────────────────────────────────────
usage() {
  echo ""
  echo "${BOLD}ez — Satellite Service Tool${RESET}"
  echo ""
  echo "${BOLD}Usage:${RESET}"
  echo "  ez <command> [-s <service>]"
  echo ""
  echo "${BOLD}Commands:${RESET}"
  printf "  %-18s %s\n" "${CYAN}install${RESET}"  "Download all Maven dependencies"
  printf "  %-18s %s\n" "${CYAN}build${RESET}"    "Compile source code"
  printf "  %-18s %s\n" "${CYAN}package${RESET}"  "Build runnable JARs (tests skipped)"
  printf "  %-18s %s\n" "${CYAN}test${RESET}"     "Run unit tests"
  printf "  %-18s %s\n" "${CYAN}clean${RESET}"    "Delete target/ output"
  printf "  %-18s %s\n" "${CYAN}run${RESET} ${YELLOW}-s <svc>${RESET}" "Start a service (spring-boot:run)"
  echo ""
  echo "${BOLD}Options:${RESET}"
  echo "  ${YELLOW}-s <service>${RESET}   Target one specific service (omit = all services)"
  echo ""
  echo "${BOLD}Registered services:${RESET}"
  for s in "${SERVICES[@]}"; do
    echo "  ${DIM}$s${RESET}"
  done
  echo ""
  echo "${BOLD}Examples:${RESET}"
  echo "  ez install                        # resolve deps for all services"
  echo "  ez build                          # compile all services"
  echo "  ez build   -s data-service        # compile one service"
  echo "  ez package -s alert-service       # build JAR for one service"
  echo "  ez test    -s ingestion-service   # test one service"
  echo "  ez clean                          # clean all services"
  echo "  ez run     -s api-gateway         # start api-gateway"
  echo ""
}

# ── Maven runner ──────────────────────────────────────────────
run_mvn() {
  local svc="$1"
  local goal="$2"
  local svc_dir="$ROOT_DIR/$svc"

  if [[ ! -d "$svc_dir" ]]; then
    echo "${RED}✗ Service directory not found: $svc_dir${RESET}"
    exit 1
  fi

  # Prefer the bundled Maven wrapper if available
  local mvn_cmd="mvn"
  [[ -x "$svc_dir/mvnw" ]] && mvn_cmd="$svc_dir/mvnw"

  echo ""
  echo "${BOLD}${CYAN}▶ $svc${RESET}  →  $goal"
  (cd "$svc_dir" && $mvn_cmd $goal) \
    && echo "${GREEN}✓ $svc — done${RESET}" \
    || { echo "${RED}✗ $svc — FAILED${RESET}"; exit 1; }
}

# ── Parse args ────────────────────────────────────────────────
CMD="${1:-}"
[[ -z "$CMD" || "$CMD" == "help" || "$CMD" == "--help" || "$CMD" == "-h" ]] \
  && usage && exit 0

shift   # consume command, remaining args are flags

SERVICE=""
while getopts ":s:" opt "$@" 2>/dev/null; do
  case "$opt" in
    s) SERVICE="$OPTARG" ;;
    :) echo "${RED}Error: -$OPTARG requires a service name.${RESET}"; exit 1 ;;
    ?) echo "${RED}Error: Unknown flag -$OPTARG.${RESET}"; exit 1 ;;
  esac
done

# If -s given, operate on that service only; otherwise all of them
if [[ -n "$SERVICE" ]]; then
  TARGETS=( "$SERVICE" )
else
  TARGETS=( "${SERVICES[@]}" )
fi

# ── Dispatch ──────────────────────────────────────────────────
case "$CMD" in

  install)
    for svc in "${TARGETS[@]}"; do
      run_mvn "$svc" "dependency:resolve -U"
    done
    ;;

  build|compile)
    for svc in "${TARGETS[@]}"; do
      run_mvn "$svc" "compile -DskipTests"
    done
    ;;

  package)
    for svc in "${TARGETS[@]}"; do
      run_mvn "$svc" "package -DskipTests"
    done
    ;;

  test)
    for svc in "${TARGETS[@]}"; do
      run_mvn "$svc" "test"
    done
    ;;

  clean)
    for svc in "${TARGETS[@]}"; do
      run_mvn "$svc" "clean"
    done
    ;;

  run)
    if [[ -z "$SERVICE" ]]; then
      echo "${RED}Error: 'ez run' requires a service.${RESET}"
      echo "  Usage: ez run -s <service-name>"
      exit 1
    fi
    run_mvn "$SERVICE" "spring-boot:run"
    ;;

  *)
    echo "${RED}Unknown command: '$CMD'${RESET}"
    usage
    exit 1
    ;;

esac
